{
    "name": "christianjbrown/user-friendly-exception",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0@dev",
        "christianjbrown/phpcs-wrapper": "dev-main",
        "christianjbrown/php-cs-fixer-wrapper": "dev-main"
    },
    "minimum-stability": "dev",
    "scripts": {
        "test": [
            "./vendor/bin/phpunit && open ./.phpunit.cache/code-coverage-html/index.html"
        ],
        "check-style": [
            "./vendor/bin/phpcs --standard=vendor/christianjbrown/phpcs-wrapper/standards/ChristianBrown/ruleset.xml ./src ./tests"
        ],
        "fix-style": [
            "./vendor/bin/php-cs-fixer fix ./src ./tests -vvv --config=vendor/christianjbrown/php-cs-fixer-wrapper/rule-sets/risky.php"
        ]
    },
    "autoload": {
        "psr-4": {
            "ChristianBrown\\UserFriendlyException\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-cs-fixer-wrapper.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/phpcs-wrapper.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/git-php-wrapper.git"
        }
    ]
}
