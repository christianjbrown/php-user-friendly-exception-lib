{
    "name": "christianjbrown/php-user-friendly-exception-lib",
    "type": "library",
    "require": {
        "php": "~8.3"
    },
    "require-dev": {
        "christianjbrown/php-code-quality-scripts": "dev-main",
        "phpunit/phpunit": "^12.0"
    },
    "scripts": {
        "test": [
            "clear && XDEBUG_MODE=coverage ./bin/phpunit --process-isolation && open ./.phpunit.cache/code-coverage-html/index.html"
        ],
        "check-style": [
            "clear && ./bin/php-cs ./src ./tests"
        ],
        "check-style-diff": [
            "clear && ./bin/php-cs-diff"
        ],
        "fix-style": [
            "clear && ./bin/php-cs-fix ./src ./tests"
        ],
        "fix-style-diff": [
            "clear && ./bin/php-cs-fix-diff"
        ]
    },
    "config": {
        "bin-dir": "bin"
    },
    "autoload": {
        "psr-4": {
            "ChristianBrown\\UserFriendlyException\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-code-quality-scripts.git"
        }
    ]
}
